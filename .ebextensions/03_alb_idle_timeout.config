# O ALB do Elastic Beanstalk usa idle timeout de 60s por padrão. Geração de texto
# com Ollama (campos de até 1000 palavras) pode levar 2–5 min — o ALB corta antes
# do Node responder e o browser mostra erro de CORS (504 sem Access-Control-Allow-Origin).
option_settings:
  aws:elbv2:loadbalancer:
    IdleTimeout: "360"
