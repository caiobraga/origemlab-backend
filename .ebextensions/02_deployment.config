# Aumenta o tempo que o EB espera pelos comandos na instância (npm install, restart, etc.).
# Timeout baixo costuma aparecer como "TimedOut: 1" / "None of the instances are sending data"
# quando o primeiro deploy com dependências novas ou rede lenta ultrapassa o limite padrão (~600s).
option_settings:
  aws:elasticbeanstalk:command:
    Timeout: "2400"
