# Geração de texto com Ollama pode levar vários minutos — o proxy nginx do EB
# corta em ~60s por padrão e o browser reporta erro de CORS (504 sem Allow-Origin).
files:
  "/etc/nginx/conf.d/ai_proxy_timeout.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      client_max_body_size 50M;
      proxy_connect_timeout 360s;
      proxy_send_timeout 360s;
      proxy_read_timeout 360s;
      send_timeout 360s;

container_commands:
  01_reload_nginx:
    command: "service nginx reload || true"
